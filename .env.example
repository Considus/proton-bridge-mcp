# Proton Bridge MCP — copy to .env or set these in your MCP client's "env" block.
# REQUIRED: the Bridge username shown in the Proton Mail Bridge app.
PROTON_USER=you@example.com

# Bridge password. Prefer the OS keychain over this file:
#   macOS : security add-generic-password -a "you@example.com" -s "proton-bridge-imap" -w
#   other : pip install keyring && keyring set proton-bridge-imap you@example.com
# PROTON_BRIDGE_PASSWORD=

# Optional: address to send From when replying via a SimpleLogin reverse-alias.
# PROTON_ALIAS_FROM=you@pm.me

# Bridge assigns ports per install — check Bridge > Settings if login fails.
PROTON_IMAP_HOST=127.0.0.1
PROTON_IMAP_PORT=1143
PROTON_SMTP_HOST=127.0.0.1
PROTON_SMTP_PORT=1025
PROTON_KEYCHAIN_SVC=proton-bridge-imap
# PROTON_ATTACH_DIR=./attachments
